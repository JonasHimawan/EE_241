  #Behavior:
      # - Produces a new image in which pixel values outside a specified
      #   intensity range is replaced with a given value.
  #Exceptions:
      # - None
  #Returns:
      # - A new image array with the same dimensions as the input image, where all
          pixel values below the minimum or above the maximum intensity
          have been replaced.
  #Parameters:
      # - image: A 2D or 3D array representing an image.
      # - min_pixel_depth: The lower bound of the allowed pixel intensity range (inclusive).
      # - max_pixel_depth: The upper bound of the allowed pixel intensity range (inclusive).
      # - replacement_val: The value assigned to pixels whose intensities fall outside the specified range.
  def subset_pixels(image, min_pixel_depth, max_pixel_depth, replacement_val):
      new_image = image.copy()
      new_image[new_image < min_pixel_depth] = replacement_val
      new_image[new_image > max_pixel_depth] = replacement_val
      return new_image
  # min_pixel_depth = 50, max_pixel_depth = 250, replacement_val = 100
  fig = plt.figure(figsize=(7, 7))
  e1_output1 = subset_pixels(image = e1_img, min_pixel_depth = 50, max_pixel_depth = 250, replacement_val = 100)
  plt.imshow(e1_output1, cmap = 'gray', vmin = 0, vmax = 255)
  plt.savefig('e1_output1.png')
  
