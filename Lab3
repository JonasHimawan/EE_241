#Behavior:
    # - Produces a smaller version of the input image with reduced resolution.
#Exceptions:
    # - None
#Returns:
    # - A new image with reduced height and width that represents a scaled down verison of the original image.
#Parameters:
    # - image: A color image represented as a 3D array.
    # - downsampling_rate: A positive integer that specifies the factor by which the resolution is reduced.
def create_thumbnail(image, downsampling_rate):
    # Segment Average Method
    H, W, C = image.shape
    new_H = int(H / downsampling_rate) 
    new_W = int(W / downsampling_rate)

    blocks = image.reshape(new_H, downsampling_rate, new_W, downsampling_rate, C)
    temp = blocks.mean(axis = 3)
    output = temp.mean(axis = 1)
    output_image = np.round(output).astype(np.uint8)      
    return output_image

fig = plt.figure(figsize=(7, 7))
